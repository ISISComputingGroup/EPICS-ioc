record(ai, "$(P):CH$(CHAN):TEMP"){
    field(DESC, "Readback value for channel $(CHAN)")
    field(EGU, "C")

    field(HIGH, "$(HIGHLIMIT)")
    field(HSV, "MAJOR")

    field(LOW, "$(LOWLIMIT)")
    field(LSV, "MAJOR")

$(IFALIASED)    info(INTEREST, "HIGH")
$(IFALIASED)    info(archive, "VAL")
# currently not archived when $(IFNOTALIASED) - could consider info(archive, "60.0 VAL")
$(IFALIASED)    info(alarm, "MOXA1262")
}
